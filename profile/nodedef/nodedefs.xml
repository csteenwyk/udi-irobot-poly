<nodeDefs>

  <!-- Controller Node -->
  <nodeDef id="irobot_controller" nodeType="139" nls="irobot_controller">
    <sts>
      <st id="ST" editor="E_STATUS"/>
    </sts>
    <cmds>
      <sends/>
      <accepts>
        <cmd id="QUERY"/>
        <cmd id="DISCOVER"/>
        <cmd id="FETCH_CREDS"/>
      </accepts>
    </cmds>
  </nodeDef>

  <!-- Robot Node -->
  <nodeDef id="irobot_robot" nodeType="139" nls="irobot_robot">
    <sts>
      <st id="ST"    editor="E_PHASE"/>   <!-- Phase -->
      <st id="BATLVL" editor="E_PERCENT"/> <!-- Battery % -->
      <st id="GV1"   editor="E_STATUS"/>  <!-- Bin full -->
      <st id="GV2"   editor="E_STATUS"/>  <!-- Bin present -->
      <st id="GV3"   editor="E_STATUS"/>  <!-- Docked -->
      <st id="GV4"   editor="E_CHARGE"/>  <!-- Charging state -->
      <st id="GV5"   editor="E_TIME"/>    <!-- Error code -->
      <st id="GV6"   editor="E_PERCENT"/> <!-- RSSI / signal -->
    </sts>
    <cmds>
      <sends/>
      <accepts>
        <cmd id="START"/>
        <cmd id="STOP"/>
        <cmd id="PAUSE"/>
        <cmd id="RESUME"/>
        <cmd id="DOCK"/>
        <cmd id="LOCATE"/>
        <cmd id="QUERY"/>
      </accepts>
    </cmds>
  </nodeDef>

</nodeDefs>
